# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key (server-only — never exposed to the browser). Needed for
# email activity logging and the reminder cron.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Email (resend.com → API Keys)
RESEND_API_KEY=re_YOUR_KEY
# Beta mode: ALL emails reroute to EMAIL_BETA_ADDRESS with the real recipient
# shown in the subject line. Set to false only at production cutover.
EMAIL_BETA_MODE=true
EMAIL_BETA_ADDRESS=bbgrossman@gmail.com
# After verifying your domain in Resend, switch FROM to your own address:
# EMAIL_FROM=Event Space by Burger Bar <events@yourdomain.com>

# Staff alerts go here when EMAIL_BETA_MODE=false (defaults to beta address)
EMAIL_INTERNAL_ADDRESS=bbgrossman@gmail.com

# Optional: protects /api/cron when deployed
CRON_SECRET=
